# Uprooted CI/CD — Required Secrets
#
# Copy to .env for local testing. In CI, these are set as GitHub Actions secrets.
# Run: gh secret set <NAME> --body "<value>" -R The-Uprooted-Project/uprooted-private

# Push releases to public repo (The-Uprooted-Project/uprooted)
# Scope: repo
PUBLIC_REPO_TOKEN=ghp_...

# Chocolatey — push .nupkg packages
# Get from: https://community.chocolatey.org/account (API Keys)
CHOCO_API_KEY=

# winget — submit PRs to microsoft/winget-pkgs
# Scope: public_repo
WINGET_GITHUB_PAT=ghp_...

# Scoop — push manifests to The-Uprooted-Project/scoop-bucket
# Scope: repo
SCOOP_GITHUB_TOKEN=ghp_...

# Homebrew — push formulas to The-Uprooted-Project/homebrew-tap
# Scope: repo
HOMEBREW_TAP_TOKEN=ghp_...

# AUR — push PKGBUILD to aur.archlinux.org via SSH
# Generate: ssh-keygen -t ed25519 -C "uprooted-bot" -f aur_ed25519 -N ""
# Add public key at: https://aur.archlinux.org/account/
AUR_SSH_PRIVATE_KEY=

# Cloudsmith — push .deb packages to APT repository
# Get from: https://cloudsmith.io (Account Settings > API Keys)
CLOUDSMITH_API_KEY=

# GitHub Gist — update dynamic badge data
# Scope: gist
GIST_TOKEN=ghp_...
